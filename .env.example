# ========================================
# REPARATIONS PLATFORM - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Use either DATABASE_URL (Render/Heroku style) OR individual variables

# Option 1: Connection string (recommended for Render)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Option 2: Individual variables (for local development)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reparations
POSTGRES_USER=reparations_user
POSTGRES_PASSWORD=your_secure_password

# ========================================
# AWS S3 STORAGE (Required for Production)
# ========================================
# Get these from AWS IAM Console after creating:
# 1. S3 bucket
# 2. IAM user with S3 permissions
# 3. Access keys for that user

S3_ENABLED=true
S3_BUCKET=reparations-documents-prod-2024
S3_REGION=us-east-2

# AWS Credentials (from IAM user access keys)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# LOCAL STORAGE (Fallback/Development)
# ========================================
# Files will be saved here if S3 is disabled or fails
STORAGE_ROOT=./storage

# ========================================
# GOOGLE VISION API (Optional - for OCR)
# ========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ========================================
# IPFS (Optional - for document hashing)
# ========================================
IPFS_ENABLED=false
IPFS_GATEWAY=https://ipfs.io/ipfs/

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# SECURITY (Optional)
# ========================================
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://danyelajunebrown.github.io,http://localhost:8080

# Session secret for authentication (generate random string)
# SESSION_SECRET=generate_a_random_secret_string_here

# ========================================
# NOTES
# ========================================
# For local development:
# - Use individual POSTGRES_* variables
# - Set S3_ENABLED=false to use local storage
# - Test with sample documents first
#
# For Render deployment:
# - Use DATABASE_URL from Render
# - Set S3_ENABLED=true
# - Add all variables in Render Dashboard → Environment
#
# Security:
# - Never commit .env file to git
# - Use different credentials for dev/prod
# - Rotate AWS keys periodically

# ========================================
# FAMILYSEARCH SCRAPER AUTHENTICATION
# ========================================
# FamilySearch uses Google OAuth — credentials cannot be typed programmatically.
# The probate scraper (and ancestor climber) supports two unattended login modes:
#
# Option A — Full cookie jar (recommended, survives session rotation):
#   1. Log in to FamilySearch in Chrome
#   2. Open DevTools → Application → Cookies → familysearch.org
#   3. Export all cookies as JSON (use "EditThisCookie" extension → Export)
#   4. Save the file and set the path below
#   The scraper will inject these cookies before each run.
FAMILYSEARCH_COOKIES=/tmp/familysearch-cookies.json
#
# Option B — Single session token (simpler, valid for ~24h per session):
#   1. Log in to FamilySearch in Chrome
#   2. Open DevTools → Application → Cookies → familysearch.org
#   3. Find the cookie named "fssessionid" and copy its value
#   4. Paste it below
#   The scraper injects this cookie before navigating.
FS_SESSION_COOKIE=
#
# If neither is set, the scraper falls back to interactive login:
#   The Chrome window (port 9222) will display the FS login page and wait
#   up to 3 minutes for you to log in manually before continuing.
#
# Note: The Mac Mini's Chrome profile (/tmp/familysearch-ancestor-climber)
# persists cookies between runs — if Chrome stays running and the session
# hasn't expired, no re-login is needed regardless of these settings.

# ========================================
# ADMIN AUTH (Apr 2026 — frontend reintegration)
# ========================================
# Bearer token that gates admin-only API endpoints:
#   /api/admin/verify
#   /api/contribute/review-queue (+ /approve, /reject)
#   /api/contribute/data-quality + /data-quality-metrics
#   /api/contribute/training/*
#   /api/ancestor-climb/pending-verification
#
# In production (NODE_ENV=production), ADMIN_TOKEN MUST be set or admin
# endpoints return 503. In development, admin endpoints are left open
# with a startup warning.
#
# Generate a token: `openssl rand -hex 32`
# Rotate after each event. Share out-of-band (not in chat or email).
ADMIN_TOKEN=
